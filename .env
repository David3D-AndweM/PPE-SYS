# Database
POSTGRES_DB=ppe_db
POSTGRES_USER=ppe_user
POSTGRES_PASSWORD=ppe_password
DATABASE_URL=postgresql://ppe_user:ppe_password@db:5432/ppe_db

# Django
SECRET_KEY=change_me_to_a_long_random_string_in_production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend
DJANGO_SETTINGS_MODULE=config.settings.development

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# CORS (comma-separated origins for the Flutter app)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# QR Code signing secret (must be strong in production)
QR_SECRET_KEY=change_me_to_a_long_random_string_for_qr_signing

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (optional — leave blank to log to console in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ppe.local

# Branding defaults
DEFAULT_ORG_NAME=AuricMines Ltd
