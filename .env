# Database
POSTGRES_DB=ppe_db
POSTGRES_USER=ppe_user
POSTGRES_PASSWORD=ppe_secure_password_2024
DATABASE_URL=postgresql://ppe_user:ppe_secure_password_2024@db:5432/ppe_db

# Django
SECRET_KEY=ppe-system-django-secret-key-production-change-this-to-random-string
DEBUG=False
ALLOWED_HOSTS=98.85.3.43,rhe19-black-tortoise-40,localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.production

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# CORS (allow requests from your server IP)
CORS_ALLOWED_ORIGINS=http://98.85.3.43,http://98.85.3.43:80,http://rhe19-black-tortoise-40

# QR Code signing secret
QR_SECRET_KEY=ppe-qr-signing-secret-key-production-change-this-to-random-string

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# Email (console logging in dev)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@ppe.local

# Branding defaults
DEFAULT_ORG_NAME=AuricMines Ltd

# Object storage (MinIO/S3) for media uploads
USE_S3=True
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_STORAGE_BUCKET_NAME=ppe-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_ADDRESSING_STYLE=path
AWS_QUERYSTRING_AUTH=False
